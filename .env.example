## Interactive Brokers (TWS / IB Gateway)
# Set these to match your local/network TWS settings.
IB_HOST=127.0.0.1
IB_PORT=7497
IB_CLIENT_ID=1

## Groq (LLM veto)
GROQ_API_KEY=

## Technical strategy selection (MVP)
# Strategy registry key. Available:
# - me_simple_v1
IQS_STRATEGY=me_simple_v1

# JSON object with strategy parameters. Examples:
# IQS_STRATEGY_PARAMS={"z_window":20,"entry_z":1.0,"exit_z":-1.0,"hurst_min":0.55,"hurst_max":0.45,"vol_window":120,"vol_cap":0.03,"take_profit_pct":0.06,"stop_loss_pct":0.03}
IQS_STRATEGY_PARAMS={}

# Data source settings (yfinance) - adjust for your use-case
IQS_YF_PERIOD=6mo
IQS_YF_INTERVAL=1d

# Position sizing policy (max notional per BUY order, in quote currency)
IQS_MAX_ORDER_NOTIONAL=2000
